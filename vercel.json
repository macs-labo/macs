{
  "ignoreCommand": "git diff --quiet $VERCEL_GIT_PREVIOUS_SHA $VERCEL_GIT_COMMIT_SHA ./:^README.md :^.github/ :^LICENSE :^cron/",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0",
      "includeFiles": "{macs/**/*.php,data/*.db,macs/templates/*.html}"
    }
  },
  "routes": [
    { "src": "/macs/(.*\\.(js|css|png|jpg|gif|ico|svg))$", "dest": "/macs/$1" },
    { "src": "/macs/(.*)", "dest": "/api/index.php" },
    { "handle": "filesystem" }
  ]
}
